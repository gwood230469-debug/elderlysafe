# Copy this file to .env and fill in real values.

# Supabase dashboard → Project Settings → API
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# (Web application type — used for Supabase's Google OAuth verification)
EXPO_PUBLIC_GOOGLE_WEB_CLIENT_ID=your-web-client-id.apps.googleusercontent.com

# GitHub Pages (or any static host) URL for web/invite-redirect/ — see that
# folder's own notes. Used as the link family members tap to join a circle.
EXPO_PUBLIC_INVITE_LANDING_URL=https://your-username.github.io/elderlysafe/web/invite-redirect/
